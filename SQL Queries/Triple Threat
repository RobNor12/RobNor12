SELECT 
  t.card4 AS card_network,
  t.card6 AS card_type,
  i.DeviceType,
  t.R_emaildomain,
  Count(*) AS total_transactions,
  SUM(t.isFraud) AS fraud_count,
  ROUND(AVG(t.isFraud) * 100, 2) AS fraud_rate_pct,

  (CASE 
    WHEN AVG(t.isFraud) > 0.5 THEN 5
    WHEN AVG(t.isFraud) > 0.1 THEN 3
    ELSE 0
  END +

  CASE 
    WHEN i.DeviceType LIKE 'mobile' THEN 2
    ELSE 1
  END +
  
  CASE
    WHEN t.card6 = 'credit' THEN 2
    ELSE 1
    END)
  
  AS risk_score
  
FROM `project-d2fe5a6c-bfb6-42c5-806.Fraud_analysis.Fraud_transactions` t
LEFT JOIN `project-d2fe5a6c-bfb6-42c5-806.Fraud_analysis.Fraud_identity` i
  ON t.TransactionID = i.TransactionID

WHERE t.R_emaildomain IS NOT NULL
AND i.DeviceType IS NOT NULL
AND t.card4 IS NOT NULL

GROUP BY 1, 2, 3, 4
HAVING fraud_count > 1
ORDER BY fraud_rate_pct DESC, risk_score DESC
